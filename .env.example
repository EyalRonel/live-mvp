# Copy to .env and fill in your keys
OPENAI_API_KEY=
BAAS_API_KEY=

# MeetingBaaS connects TO your machine, so it needs a public wss:// URL.
# Easiest: paste an ngrok authtoken (free at https://dashboard.ngrok.com) and a
# tunnel is opened automatically.
NGROK_AUTHTOKEN=

# Advanced: if you run your own tunnel, set its public URL here instead of
# NGROK_AUTHTOKEN (must point at the local PORT below; ws:// is upgraded to wss).
# PUBLIC_WS_URL=wss://your-tunnel.example.com

# Local port the audio WebSocket server listens on (default 8080).
# PORT=8080

# The agent's name. It joins the meeting under this name and only replies when
# addressed by it (default "Rall").
# AGENT_NAME=Rall

# Optional comma-separated wake-word variants, for when speech-to-text mishears
# the name (e.g. Rall -> Raul, Ral). Matched in addition to AGENT_NAME.
# AGENT_ALIASES=Raul,Ral,Rahl
