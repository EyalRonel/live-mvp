# Copy to .env and fill in your keys.

# --- OpenAI (all channels) ---
OPENAI_API_KEY=
# Text model the agent brain (src/agent/brain.ts) uses (default gpt-4o-mini).
# AGENT_MODEL=gpt-4o-mini

# --- Google Meet channel (MeetingBaaS) ---
BAAS_API_KEY=

# --- Phone + SMS channels (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio number in E.164 (voice + SMS capable).
TWILIO_PHONE_NUMBER=+19787658615

# --- Public tunnel (providers connect TO this machine) ---
# Easiest: an ngrok authtoken (free at https://dashboard.ngrok.com) opens a tunnel
# automatically. Note: ngrok free allows ONE tunnel — run one channel at a time.
NGROK_AUTHTOKEN=
# Advanced: use your own tunnel instead of ngrok (wss:// is upgraded/downgraded as needed).
# PUBLIC_WS_URL=wss://your-tunnel.example.com

# --- Agent persona ---
# The agent's name: meeting display name + wake word (default "Rally").
# AGENT_NAME=Rally
# Comma-separated wake-word variants for when speech-to-text mishears the name.
# AGENT_ALIASES=Raul,Ral,Rahl
# Voice heard on calls/meetings: alloy, ash, ballad, coral, echo, sage, shimmer,
# verse, marin, cedar (default "marin"; preview at openai.fm).
# AGENT_VOICE=marin
# Personality/delivery tone — shapes word choice + spoken delivery.
# AGENT_TONE=warm, upbeat, and concise

# --- Local ports (one per channel; only matters if you run several) ---
# PORT=8080         # google-meet audio WebSocket server
# PHONE_PORT=8081   # phone-call HTTP + media WebSocket server
# SMS_PORT=8082     # sms webhook server
